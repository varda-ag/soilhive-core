exports[`Header component renders component correctly on desktop 1`] = `
<div>
  <header
    class="Header"
  >
    <div
      class="Logo"
      data-testid="sh-header-logo"
    >
      <img
        alt="Logo"
        src="logo.png"
      />
    </div>
    <div
      class="Menu"
    >
      <nav
        class="Nav"
        data-testid="sh-header-nav"
      >
        <a
          aria-current="page"
          class="Active"
          data-discover="true"
          data-testid="sh-header-nav-link"
          href="/"
        >
          <span
            class="LinkText"
          >
            Availability
          </span>
        </a>
        <a
          class=""
          data-discover="true"
          data-testid="sh-header-nav-link"
          href="/legal"
        >
          <span
            class="LinkText"
          >
            Legal
          </span>
        </a>
        <a
          class=""
          data-discover="true"
          data-testid="sh-header-nav-link"
          href="/admin"
        >
          <span
            class="LinkText"
          >
            Admin
          </span>
        </a>
        <a
          class=""
          data-discover="true"
          data-testid="sh-header-nav-link"
          href="/test-module-route"
        >
          <span
            class="LinkText"
          >
            test-module-name
          </span>
        </a>
      </nav>
      <div
        class="Additional"
      >
        <div
          data-testid="downloads-status-mock"
        >
          Downloads Status component
        </div>
        <div
          data-testid="account-widget-mock"
        >
          Account Widget
        </div>
      </div>
    </div>
  </header>
</div>
`;

