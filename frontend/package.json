    "math.gl": "^4.1.0",
    "oidc-client-ts": "^3.4.0",
    "primereact": "^10.9.7",
    "quill": "^2.0.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-easy-crop": "^5.5.7",
    "react-i18next": "^16.5.4",
