    "classnames": "^2.5.1",
    "compression": "^1.8.0",
    "dompurify": "^3.3.3",
    "express": "^5.1.0",
    "geojson": "^0.5.0",
    "geojson2h3": "^1.2.0",
    "h3-js": "^4.3.0",
    "html-react-parser": "^5.2.17",
