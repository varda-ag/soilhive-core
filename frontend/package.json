{
  "name": "frontend",
  "private": true,
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "build:client": "rsbuild build --environment web",
    "build:ssr": "rsbuild build --environment web --environment ssr",
    "dev": "pnpm build:ssr && run-p dev:watch dev:ssr-run",
    "dev:watch": "rsbuild build --watch --environment ssr",
    "dev:ssr-run": "node --watch dist/server/index.cjs",
    "dev:client": "rsbuild dev --environment web",
    "start": "node dist/server/index.cjs",
    "preview": "rsbuild preview",
    "test": "jest --bail --passWithNoTests",
    "test:watch": "jest --clearCache && jest --watch",
    "test:coverage": "jest --clearCache && jest --coverage",
    "test:snapshot": "jest -u"
  },
  "dependencies": {
