{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "build": "tsc && npm run copy-openapi && npm run copy-assets",
    "copy-openapi": "copyfiles -u 1 'src/openapi.yaml' 'dist/'",
    "copy-assets": "copyfiles -u 1 'src/assets/**/*' 'dist/'",
    "start": "node dist/app.js",
    "dev": "nodemon --exec 'ts-node --transpile-only' src/app.ts --watch src/**/*.ts src/openapi.yaml",
    "test": "jest --runInBand --bail --detectOpenHandles --coverage --collectCoverageFrom='src/**/*.ts'",
    "test:watch": "jest --detectOpenHandles --watch",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@aws-sdk/credential-providers": "^3.943.0",
    "@aws-sdk/rds-signer": "^3.943.0",
    "@flystorage/aws-s3": "^1.2.0",
    "@flystorage/file-storage": "^1.2.0",
    "@flystorage/local-fs": "^1.2.0",
    "@flystorage/multer-storage": "^1.2.0",
    "@turf/turf": "^7.3.1",
    "@types/bcrypt": "^6.0.0",
    "baseline-browser-mapping": "^2.9.17",
    "bcrypt": "^6.0.0",
    "commander": "^14.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-openapi-validator": "^5.6.0",
    "extract-zip": "^2.0.1",
    "gdal-async": "^3.12.1",
    "geojson-validation": "^1.0.2",
    "http-status-codes": "^2.3.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "multer": "^2.0.2",
    "node-object-hash": "^3.1.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "@tsconfig/node-lts": "^22.0.2",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/supertest": "^6.0.3",
    "copyfiles": "^2.4.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest.beforeEach.ts"
    ],
    "globalSetup": "<rootDir>/tests/jest.setup.ts",
    "globalTeardown": "<rootDir>/tests/jest.teardown.ts",
    "forceExit": true,
    "maxWorkers": 1
  }
}
